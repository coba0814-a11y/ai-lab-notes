---
const nav = [
  { href: '/', label: 'すべての記録' },
  { href: '/about/', label: 'このノートについて' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">
      <span class="brand__mark">AI</span>
      <span class="brand__text">
        <span class="brand__title">Lab Notes</span>
        <span class="brand__subtitle">AIツール実験ノート</span>
      </span>
    </a>
    <nav aria-label="サイト内ナビゲーション">
      <ul class="nav-list">
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--paper);
    position: relative;
    z-index: 10;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.4rem;
    padding-bottom: 1.4rem;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink);
  }
  .brand:hover {
    color: var(--ink);
  }
  .brand__mark {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    border: 1.5px solid var(--margin-rule);
    color: var(--margin-rule);
    padding: 0.25rem 0.4rem;
    line-height: 1;
    transform: rotate(-3deg);
  }
  .brand__title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    display: block;
  }
  .brand__subtitle {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
  }
  .nav-list {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    font-size: 0.92rem;
    color: var(--ink-soft);
    text-decoration: none;
  }
  .nav-list a:hover {
    color: var(--margin-rule);
  }
</style>
