---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';

interface Props {
  title: string;
  description: string;
  entryNumber: number;
  pubDate: Date;
  updatedDate?: Date;
  tools: string[];
  status: 'published' | 'draft';
  readingMinutes?: number;
}
const { title, description, entryNumber, pubDate, updatedDate, tools, status, readingMinutes } = Astro.props;
const paddedNumber = String(entryNumber).padStart(3, '0');
const formatted = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric', month: '2-digit', day: '2-digit',
});
---

<BaseLayout title={title} description={description}>
  <article class="container post notebook fade-in-up">
    <p class="entry-number">
      ENTRY No.{paddedNumber} — 記録日 {formatted}
      {readingMinutes && <span class="reading-time">/ 約{readingMinutes}分</span>}
      {status === 'draft' && <span class="draft-note">※下書き:公開前に体験談を追記すること</span>}
    </p>
    <h1>{title}</h1>
    {tools.length > 0 && (
      <ul class="tool-list">
        {tools.map((tool) => <li>{tool}</li>)}
      </ul>
    )}

    <div class="prose">
      <slot />
    </div>

    <AdSlot slot="in-article" />

    <p class="back-link"><a href="/">← 一覧に戻る</a></p>
  </article>
</BaseLayout>

<style>
  .post {
    padding-top: 2.5rem;
    padding-bottom: 2rem;
  }
  .post h1 {
    font-size: 1.9rem;
    margin: 0.6rem 0 1rem;
  }
  .draft-note {
    color: #7a4a12;
    background: var(--accent-amber-soft);
    padding: 0.08rem 0.5rem;
    margin-left: 0.5rem;
    display: inline-block;
    transform: rotate(-2deg);
    border-radius: 1px;
  }
  .tool-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0;
  }
  .tool-list li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent-steel);
    background: var(--accent-amber-soft);
    padding: 0.15rem 0.5rem;
  }
  .reading-time {
    color: var(--ink-faint);
  }
  .prose :global(h2) {
    font-size: 1.35rem;
    margin-top: 2.4rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px dashed var(--border);
  }
  .prose :global(h3) {
    font-size: 1.1rem;
    margin-top: 1.6rem;
  }
  .prose :global(p) {
    margin: 1rem 0;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4rem;
  }
  .prose :global(li) {
    margin: 0.35rem 0;
  }
  /* 「📝 体験を追記」ブロックを付箋メモ風に */
  .prose :global(blockquote) {
    border-left: none;
    margin: 1.6rem 0;
    padding: 0.9rem 1.1rem;
    color: #6b5426;
    background:
      linear-gradient(var(--accent-amber-soft), var(--accent-amber-soft)) padding-box;
    border-radius: 2px;
    box-shadow: var(--shadow-soft);
    font-style: normal;
    font-size: 0.95rem;
    position: relative;
    transform: rotate(-0.4deg);
  }
  .prose :global(blockquote::before) {
    content: '';
    position: absolute;
    top: -7px;
    left: 50%;
    transform: translateX(-50%) rotate(1.5deg);
    width: 74px;
    height: 14px;
    background: rgba(184, 86, 74, 0.28);
  }
  .prose :global(blockquote p) {
    margin: 0.35rem 0;
  }
  .prose :global(code) {
    background: var(--paper-raised);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 0.08rem 0.35rem;
    font-size: 0.86em;
  }
  .prose :global(a) {
    text-decoration-color: var(--accent-amber);
  }
  .back-link {
    margin-top: 2rem;
  }
</style>
