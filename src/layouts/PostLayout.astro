---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';

interface Props {
  title: string;
  description: string;
  entryNumber: number;
  pubDate: Date;
  updatedDate?: Date;
  tools: string[];
  status: 'published' | 'draft';
}
const { title, description, entryNumber, pubDate, updatedDate, tools, status } = Astro.props;
const paddedNumber = String(entryNumber).padStart(3, '0');
const formatted = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric', month: '2-digit', day: '2-digit',
});
---

<BaseLayout title={title} description={description}>
  <article class="container post notebook">
    <p class="entry-number">
      ENTRY No.{paddedNumber} — 記録日 {formatted}
      {status === 'draft' && <span class="draft-note">※下書き:公開前に体験談を追記すること</span>}
    </p>
    <h1>{title}</h1>
    {tools.length > 0 && (
      <ul class="tool-list">
        {tools.map((tool) => <li>{tool}</li>)}
      </ul>
    )}

    <div class="prose">
      <slot />
    </div>

    <AdSlot slot="in-article" />

    <p class="back-link"><a href="/">← 一覧に戻る</a></p>
  </article>
</BaseLayout>

<style>
  .post {
    padding-top: 2.5rem;
    padding-bottom: 2rem;
  }
  .post h1 {
    font-size: 1.9rem;
    margin: 0.6rem 0 1rem;
  }
  .draft-note {
    color: var(--margin-rule);
    margin-left: 0.5rem;
  }
  .tool-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0;
  }
  .tool-list li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent-steel);
    background: var(--accent-amber-soft);
    padding: 0.15rem 0.5rem;
  }
  .prose :global(h2) {
    font-size: 1.35rem;
    margin-top: 2.2rem;
  }
  .prose :global(h3) {
    font-size: 1.1rem;
    margin-top: 1.6rem;
  }
  .prose :global(p) {
    margin: 1rem 0;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent-amber);
    margin: 1.4rem 0;
    padding: 0.2rem 0 0.2rem 1rem;
    color: var(--ink-soft);
    font-style: italic;
  }
  .back-link {
    margin-top: 2rem;
  }
</style>
