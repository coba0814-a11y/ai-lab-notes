---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import AdSlot from '../components/AdSlot.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sorted = allPosts.sort((a, b) => b.data.entryNumber - a.data.entryNumber);
---

<BaseLayout
  title="AIツール実験ノート"
  description="大学生がGemini・Claude・Perplexity・NotebookLMなどのAIツールを実際に使ってみた記録。専門知識より、実際に使った一次情報を積み重ねるノート。"
>
  <section class="hero">
    <div class="container">
      <p class="entry-number">FIELD NOTES / 001—</p>
      <h1>
        AIツールを、<span class="mark">使いながら</span>記録する。
      </h1>
      <p class="hero__lead">
        専門家の解説ではなく、実際に手を動かした一次記録。
        レポート、就活のES、日々の調べ物――大学生活の中で
        AIツールをどう使い、何が良くて何が微妙だったのかを
        実験ノートのように残していきます。
      </p>
    </div>
  </section>

  <section class="container notebook posts">
    {sorted.map((post) => (
      <PostCard
        entryNumber={post.data.entryNumber}
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tools={post.data.tools}
        href={`/posts/${post.id}/`}
        status={post.data.status}
      />
    ))}
  </section>

  <div class="container">
    <AdSlot slot="in-article" />
  </div>
</BaseLayout>

<style>
  .hero {
    padding: 3.5rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
  }
  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    max-width: 18ch;
    margin: 0.5rem 0 1.2rem;
  }
  .hero__lead {
    max-width: 38rem;
    color: var(--ink-soft);
    font-size: 1.02rem;
  }
  .posts {
    padding-top: 2.5rem;
  }
</style>
